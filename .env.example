# Optional: copy to .env to override compose defaults.
# Docker Compose reads this file automatically for ${VAR} substitution.

# Server
PORT=8000

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=convhub
POSTGRES_PORT=5432

# Backend
APP_NAME=convhub-api
APP_ENV=development
DEBUG=false
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Secrets (not used by compose yet)
JWT_SECRET=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
