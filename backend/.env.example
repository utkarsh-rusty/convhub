# Application
APP_NAME=convhub-api
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database (async SQLAlchemy / asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/convhub

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT
JWT_SECRET_KEY=dev-only-change-me-in-production-use-32-chars-min
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# AI Gateway
AI_PROVIDER=mock
AI_MODEL=claude-sonnet-4-20250514
AI_SYSTEM_PROMPT=You are a helpful assistant.
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
AI_PROVIDER=ollama

# Workspace AI account credential encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
CREDENTIALS_ENCRYPTION_KEY=

# Demo & Testing Toolkit (set true to expose /demo endpoints and UI)
ENABLE_DEMO_MODE=true
